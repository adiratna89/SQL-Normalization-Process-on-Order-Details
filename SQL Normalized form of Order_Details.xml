<?xml version="1.0"?>

<resultset statement="select
c.CustomerName,
p.Product_Name,
o.Quantities,
s.Supplier_Name
from Order_details o
join customers c ON o.CustomerID = c.CustomerID
join Products p on o.ProductID = p.ProductID
join Suppliers s on p.SupplierID = s.SupplierID
LIMIT 0, 1000
"
